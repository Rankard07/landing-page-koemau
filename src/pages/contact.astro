---
import Layout from "../layouts/Layout.astro"
---
<Layout>
  <!-- Contact Header -->
  <section class="bg-gradient-to-r from-orange-500 to-orange-600 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-2"><i class="fas fa-phone mr-3"></i>Hubungi Kami</h1>
      <p class="text-lg">Kami siap melayani pesanan Anda dengan sepenuh hati</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold mb-8 text-gray-500">Informasi Kontak</h2>
          
          <div class="space-y-6">
            <!-- WhatsApp -->
            <div class="flex items-start gap-4">
              <div class="text-4xl text-orange-600"><i class="fas fa-comments"></i></div>
              <div>
                <h3 class="text-xl font-bold mb-2 text-gray-500">WhatsApp</h3>
                <p class="text-orange-500 mb-2">Pesan mudah melalui WhatsApp kami</p>
                <a href="https://wa.me/628123456789?text=Halo%20Dapur%20Koemau%21%20Saya%20ingin%20memesan%20produk%20Anda." class="inline-block bg-green-500 text-white px-6 py-2 rounded-full font-bold hover:bg-green-600 transition">
                  <i class="fab fa-whatsapp mr-2"></i>Chat WhatsApp
                </a>
                <p class="text-orange-500 mt-2">+62 812 3456 789</p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="text-4xl text-orange-600"><i class="fas fa-envelope"></i></div>
              <div>
                <h3 class="text-xl font-bold mb-2 text-gray-500">Email</h3>
                <p class="text-orange-500 mb-2">Kirim pertanyaan atau pesanan khusus</p>
                <a href="mailto:info@koemau.com" class="text-orange-600 font-bold hover:text-orange-700 transition">
                  info@koemau.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="text-4xl text-orange-600"><i class="fas fa-phone"></i></div>
              <div>
                <h3 class="text-xl font-bold mb-2 text-gray-500">Telepon</h3>
                <p class="text-orange-500 mb-2">Hubungi kami melalui telepon</p>
                <a href="tel:+628123456789" class="text-orange-600 font-bold hover:text-orange-700 transition">
                  +62 812 3456 789
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="text-4xl text-orange-600"><i class="fas fa-map-marker-alt"></i></div>
              <div>
                <h3 class="text-xl font-bold mb-2 text-gray-500">Lokasi</h3>
                <p class="text-orange-500 mb-2">Kunjungi kami untuk melihat tempat kami</p>
                <a href="/location" class="inline-block text-orange-600 font-bold hover:text-orange-700 transition">
                  Lihat Lokasi di Peta →
                </a>
              </div>
            </div>

            <!-- Jam Operasional -->
            <div class="flex items-start gap-4">
              <div class="text-4xl text-orange-600"><i class="fas fa-clock"></i></div>
              <div>
                <h3 class="text-xl font-bold mb-2 text-gray-500">Jam Operasional</h3>
                <!-- <div class="text-orange-500 space-y-1">
                  <p><i class="fas fa-calendar-alt mr-2"></i>Senin - Jumat: 08:00 - 20:00</p>
                  <p><i class="fas fa-calendar-alt mr-2"></i>Sabtu - Minggu: 09:00 - 21:00</p>
                  <p class="text-sm mt-2">*Waktu Pengiriman Tergantung Ketersediaan</p>
                </div> -->
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-3xl font-bold mb-8 text-gray-500">Kirim Pesan</h2>
          
          <div class="bg-gray-50 p-8 rounded-lg">
            <form id="contactForm" class="space-y-6">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Nama Anda</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none text-black" placeholder="John Doe">
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" placeholder="john@example.com">
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Nomor Telepon</label>
                <input type="tel" id="phone" name="phone" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" placeholder="+62 812 3456 789">
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Pesan</label>
                <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" placeholder="Tulis pesan Anda di sini..."></textarea>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="w-full bg-orange-600 text-white font-bold py-2 rounded-lg hover:bg-orange-700 transition">
                <i class="fab fa-whatsapp mr-2"></i>Kirim via WhatsApp
              </button>
            </form>
            
            <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
              <p class="text-sm text-blue-800"><i class="fas fa-lightbulb mr-2"></i><strong>Tip:</strong> Untuk respons lebih cepat, hubungi kami langsung melalui WhatsApp di tombol di atas!</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Order Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12 text-gray-500">Cara Memesan</h2>
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl font-bold text-orange-600 mb-4">1</div>
          <h3 class="font-bold mb-2 text-gray-400">Hubungi Kami</h3>
          <p class="text-orange-500 text-sm">Hubungi melalui WhatsApp atau Telepon</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl font-bold text-orange-600 mb-4">2</div>
          <h3 class="font-bold mb-2 text-gray-400">Pilih Menu</h3>
          <p class="text-orange-500 text-sm">Pilih produk dan jumlah yang Anda inginkan</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl font-bold text-orange-600 mb-4">3</div>
          <h3 class="font-bold mb-2 text-gray-400">Konfirmasi</h3>
          <p class="text-orange-500 text-sm">Kami konfirmasi pesanan dan waktu pengambilan</p>
        </div>
        <!-- <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl font-bold text-orange-600 mb-4">4</div>
          <h3 class="font-bold mb-2">Pengiriman</h3>
          <p class="text-orange-500 text-sm">Pesanan diantar tepat waktu dengan kemasan aman</p>
        </div> -->
      </div>
    </div>
  </section>

  <script define:vars={{}} is:inline>
    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value;
      const message = document.getElementById('message').value;
      
      const whatsappMessage = `*Formulir Kontak Dapur Koemau*\n\nNama: ${name}\nEmail: ${email}\nNo. Telepon: ${phone}\n\nPesan: ${message}`;
      const whatsappUrl = `https://wa.me/628123456789?text=${encodeURIComponent(whatsappMessage)}`;
      
      window.open(whatsappUrl, '_blank');
    });
  </script>
</Layout>
