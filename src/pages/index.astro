---
import Layout from "../layouts/Layout.astro"

const foodItems = [
  // Folder Siomay
  { image: "/assets/Siomay/siomay-25.jpeg", name: "Siomay", description: "Siomay tradisional dengan soal nikmat" },
  { image: "/assets/Siomay/pangsit.jpeg", name: "Pangsit", description: "Pangsit tradisional dengan soal nikmat" },
  // Folder Dimsum
  { image: "/assets/Dimsum/dimsum.jpeg", name: "Dimsum", description: "Dimsum lezat dibuat dengan bahan segar" },
  // Folder Katsu
  { image: "/assets/Katsu/katsu.jpeg", name: "Katsu", description: "Katsu crispy dengan saus spesial" },
  // Folder Risol & Corndog
  { image: "/assets/Risol-Corndog/risol-5-ayam-pds-bolognaise-sayur.jpeg", name: "Risol", description: "Risol isi pilihan (ayam pedas, bolognaise, sayur)" },
  { image: "/assets/Risol-Corndog/corndog-6.jpeg", name: "Corndog", description: "Corndog dengan lapisan renyah dan isian lezat" },
  // Folder Cireng
  { image: "/assets/Cireng/display-cireng.jpeg", name: "Cireng", description: "Cireng gurih tradisional Bandung" },
  // Folder Nugget
  { image: "/assets/Nugget/spicy-chicken-10-ayam.jpeg", name: "Spicy Chicken", description: "Ayam Pedas gurih dan empuk" },
  { image: "/assets/Nugget/ebi-furai-12.jpeg", name: "Ebi Furai", description: "Udang gurih dan empuk" },
  { image: "/assets/Nugget/egg-chicken-roll-gpt.jpeg", name: "Egg Chicken Roll", description: "Ayam telur gulung yang lezat" },
  { image: "/assets/Nugget/kaki-naga-10-ayam-ikan.jpeg", name: "Kaki Naga", description: "Kaki Naga ayam dan Ikan yang renyah dan empuk" },
  { image: "/assets/Nugget/shrimp-roll-10-udang-ayam.jpeg", name: "Shrimp Roll", description: "Olahan Udang dengan ayam yang renyah dan empuk" },
  { image: "/assets/Nugget/shrimp-cheese-10.jpeg", name: "Shrimp Cheese", description: "Olahan Udang yang berisi keju renyah" },
];
---
<Layout>
  <!-- Hero Section -->
  <section class="relative bg-orange-300 text-gray-800 py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-4">
        <i class="fas fa-utensils mr-3 text-goldenrod"></i>Koemau
      </h1>
      <!-- <p class="text-xl md:text-2xl mb-4">Menyajikan kelezatan Dimsum dan Frozen Food berkualitas tinggi untuk setiap momen istimewa Anda.</p> -->
      <p class="text-lg mb-8 max-w-2xl mx-auto">Menyajikan kelezatan Dimsum dan Frozen Food berkualitas tinggi untuk setiap momen istimewa Anda.</p>
      <a href="https://wa.me/6281298809641?text=Halo%20Koemau%21%20Saya%20ingin%20memesan%20produk%20Anda." class="inline-block bg-goldenrod text-white px-8 py-3 rounded-full font-bold text-lg hover:opacity-90 transition">
        <i class="fab fa-whatsapp mr-2"></i>Pesan Sekarang via WhatsApp
      </a>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-16 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-center mb-12 text-white">Mengapa Memilih Koemau?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-beige p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl mb-4"><i class="fas fa-home text-goldenrod"></i></div>
          <h3 class="text-xl font-bold mb-2 text-gray-800">Harga Rumahan, Kualitas Mewah</h3>
          <p class="text-goldenrod">Sebagai reseller berbasis rumahan, kami memangkas biaya operasional besar untuk memberikan harga yang sangat terjangkau—jauh di bawah harga pasaran dan kafe—tanpa mengurangi standar rasa.</p>
        </div>
        <div class="bg-beige p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl mb-4"><i class="fas fa-star text-goldenrod"></i></div>
          <h3 class="text-xl font-bold mb-2 text-gray-800">Kurasi Rasa yang Teruji</h3>
          <p class="text-goldenrod">Kami bukan sekadar menjual, kami adalah penyeleksi. Setiap produk (Dimsum hingga Corndog) telah kami pilih berdasarkan standar rasa keluarga yang lezat, alami, dan bebas pengawet.</p>
        </div>
        <div class="bg-beige p-6 rounded-lg shadow-md text-center">
          <div class="text-4xl mb-4"><i class="fas fa-user-shield text-goldenrod"></i></div>
          <h3 class="text-xl font-bold mb-2 text-gray-800">Kualitas Terjaga & Halal</h3>
          <p class="text-goldenrod">Meski harga ekonomis, kesehatan tetap prioritas. Kami hanya memilih produk dari produsen terpercaya yang menyediakan variasi frozen food yang lengkap, halal, dan bergizi dalam satu tempat yang mudah dijangkau melalui Google Maps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Section -->
  <section id="menu" class="py-16 bg-beige">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-center mb-4 text-gray-800">
        <i class="fas fa-list mr-3 text-goldenrod"></i>Menu Kami
      </h2>
      <p class="text-center mb-12 max-w-2xl mx-auto text-goldenrod">Pilihan Frozen Food lezat yang telah menjadi favorit pelanggan kami</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {foodItems.map((item) => (
          <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition transform hover:scale-105">
            <div class="relative overflow-hidden h-64 bg-gray-200">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-bold mb-2 text-gray-800">{item.name}</h3>
              <p class="text-goldenrod mb-4">{item.description}</p>
              <a href={`https://wa.me/6281298809641?text=Halo%20Koemau%21%20Saya%20ingin%20memesan%20${item.name}%20anda.`} target="_blank" class="w-full block text-center text-white py-2 rounded-lg hover:opacity-90 transition font-medium bg-goldenrod">
                Pesan Sekarang
              </a>
              {/* {<a href="}" class="w-full block text-center bg-orange-600 text-white py-2 rounded-lg hover:bg-orange-700 transition font-medium">
                Pesan Sekarang
              </a>} */}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- CTA Section -->
  <section class="bg-charcoal text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-4">Siap Memesan?</h2>
      <p class="text-xl mb-8">Hubungi kami melalui WhatsApp untuk pemesanan mudah dan cepat</p>
      <a href="-" class="inline-block px-8 py-3 rounded-full font-bold text-lg hover:opacity-90 transition bg-goldenrod text-white">
        <i class="fab fa-whatsapp mr-2"></i>Chat via WhatsApp
      </a>
      <!-- <a href="https://wa.me/6281298809641?text=Halo%20Dapur%20Koemau%21%20Saya%20ingin%20memesan%20produk%20Anda." class="inline-block bg-white text-orange-600 px-8 py-3 rounded-full font-bold text-lg hover:bg-gray-100 transition">
        <i class="fab fa-whatsapp mr-2"></i>Chat via WhatsApp
      </a> -->
    </div>
  </section>
</Layout>
