  <!-- CTA Section -->
  <section class="bg-beige text-black py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-4">Ingin Merasakan Kelezatan Kami?</h2>
      <p class="text-xl mb-8">Bergabunglah dengan ribuan pelanggan puas kami hari ini</p>
