---
import { Image } from 'astro:assets';
import LogoKoemau from 'public/Logo Koemau2.png';
---

<nav class="fixed top-0 w-full bg-white/80 backdrop-blur-md z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-orange-500 hover:text-orange-700 transition flex items-center justify-center gap-2">
      <Image 
  src={LogoKoemau} 
  alt="Logo Koemau" 
  width={48} 
  height={48} 
  loading="eager"  fetchpriority="high" />
      Koemau
    </a>
    
    <div class="hidden md:flex gap-8 font-medium">
      <a href="/" class="text-gray-700 hover:text-orange-600 transition flex items-center gap-2">
        <!-- Home Icon from Font Awesome -->
        <i class="fas fa-home text-lg"></i>
        Home
      </a>
      <a href="/#menu" class="text-gray-700 hover:text-orange-600 transition">Menu</a>
      <a href="/about" class="text-gray-700 hover:text-orange-600 transition">About</a>
      <a href="/contact" class="text-gray-700 hover:text-orange-600 transition">Contact</a>
      <a href="/location" class="text-gray-700 hover:text-orange-600 transition">Location</a>
    </div>

    <a 
  href="https://wa.me/628123456789" 
  target="_blank"
  class="bg-orange-600 text-white px-5 py-2 rounded-full hover:bg-orange-700 transition font-medium flex items-center gap-2"
>
  <!-- <i class="fab fa-whatsapp text-lg text-green-500"></i> -->
  Contact
</a>
  </div>
</nav>